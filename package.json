{
  "name": "vitals-scss",
  "version": "0.9.0",
  "description": "A minimalistic bundle of a few CSS/Sass tools for building modern, flexible websites: an improved normalize, shorthand stuff for flexbox and grid, and a fluid sizing function.",
  "author": "Garrett Whitehorn",
  "license": "MIT",
  "homepage": "https://github.com/garrettw/vitals",
  "bugs": "https://github.com/garrettw/vitals/issues",
  "keywords": [
    "sass",
    "flexbox",
    "grid",
    "semantic",
    "css",
    "grid-layout",
    "layout",
    "modern",
    "vitals",
    "vitals-grid",
    "scss",
    "scss-library",
    "sass-library",
    "fluid"
  ],
  "main": "scss/_vitals.scss",
  "style": "css/vitals.css",
  "sass": "scss/_vitals.scss",
  "browser": "css/vitals.css",
  "repository": {
    "url": "https://github.com/garrettw/vitals",
    "type": "git"
  },
  "files": [
    "scss/*",
    "css/*"
  ],
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.40",
    "postcss-cli": "^11.0.1",
    "sass": "^1.75.0",
    "stylelint": "^17.14.0",
    "stylelint-checkstyle-formatter": "^0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0"
  },
  "scripts": {
    "dev": "npm run watch",
    "watch": "concurrently \"npm run watch:sass\" \"npm run watch:postcss\"",
    "watch:sass": "sass --watch scss/_vitals.scss:css/vitals.css",
    "watch:postcss": "postcss css/vitals.css --use autoprefixer -o css/vitals.css --map --watch",
    "compile": "sass scss/_vitals.scss css/vitals.css && postcss css/vitals.css --use autoprefixer -o css/vitals.css --map",
    "minify": "sass --style=compressed scss/_vitals.scss css/vitals.min.css && postcss css/vitals.min.css --use autoprefixer -o css/vitals.min.css",
    "build": "npm run compile && npm run minify",
    "start": "npm run watch",
    "prepare": "npm run build",
    "lint:css": "stylelint \"scss/**/*.scss\" || exit 0",
    "lint:css-checkstyle": "stylelint \"scss/**/*.scss\" --custom-formatter ./node_modules/stylelint-checkstyle-formatter/index.js || exit 0"
  },
  "browserslist": [
    "last 2 years and > 0.5% in US",
    "last 2 years and > 0.5%",
    "edge >= 88",
    "safari >= 14",
    "ios >= 14",
    "Firefox ESR"
  ]
}
